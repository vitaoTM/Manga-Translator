<div class="max-w-2xl mx-auto pb-20">
  <h1 class="text-3xl font-bold text-white mb-2">Upload Images</h1>
  <p class="text-zinc-500 text-sm mb-12">
    Supports Japanese, Chinese, Korean, and more. Bulk upload supported.
  </p>

  <%= form_with url: translation_batches_path, method: :post,
        html: { enctype: "multipart/form-data" } do |f| %>
    <div class="mb-8">
      <%= f.label :title, "BATCH NAME", class: "block text-[10px] font-bold tracking-widest text-zinc-500 mb-3" %>
      <%= f.text_field :title,
            placeholder: "e.g. Chapter 42 — One Piece",
            class: "w-full bg-[#03030b] border border-zinc-800 rounded-lg text-zinc-100 px-4 py-3 text-sm focus:border-violet-500 focus:ring-1 focus:ring-violet-500 focus:outline-none transition-all" %>
    </div>

    <div class="mb-10" data-controller="model-selector">
      <label class="block text-[10px] font-bold tracking-widest text-zinc-500 mb-3">
        LLM PROVIDER & MODEL
      </label>

      <div class="flex bg-[#03030b] border border-zinc-800 rounded-t-lg overflow-hidden">
        <% TranslationBatch::PROVIDERS.each_with_index do |(key, cfg), i| %>
          <button
            type="button"
            data-model-selector-target="tab"
            data-provider="<%= key %>"
            data-action="click->model-selector#selectProvider"
            class="
              flex-1 text-[10px] font-bold tracking-widest uppercase py-3 border-r last:border-r-0 border-zinc-800
              <%= i == 0 ? 'bg-violet-600 text-white shadow-inner' : 'text-zinc-500 hover:text-zinc-300' %>
            "
          >
            <%= cfg[:label] %>
          </button>
        <% end %>
      </div>

      <% TranslationBatch::PROVIDERS.each_with_index do |(key, cfg), i| %>
        <div
          data-model-selector-target="panel"
          data-provider="<%= key %>"
          class="border border-t-0 border-zinc-800 rounded-b-lg p-6 bg-[#0a0a1a] <%= i == 0 ? '' : 'hidden' %>"
        >
          <input
            type="hidden"
            name="model_provider"
            value="<%= key %>"
            data-model-selector-target="providerInput"
            <%= i == 0 ? '' : 'disabled' %>
          >

          <% if key == "ollama" %>
            <select name="model_name"
                    data-model-selector-target="modelSelect"
                    data-action="change->model-selector#toggleCustom"
                    <%= i == 0 ? '' : 'disabled' %>
                    class="w-full bg-[#03030b] border border-zinc-800 text-zinc-200 px-4 py-2.5 rounded-lg text-sm focus:border-violet-500 focus:outline-none">
              <% cfg[:models].each do |label, val| %>
                <option value="<%= val %>"><%= label %></option>
              <% end %>
            </select>
            <div data-model-selector-target="customField" class="hidden mt-4">
              <input
                type="text"
                name="custom_model_name"
                autocomplete="off"
                placeholder="e.g. bakllava, moondream"
                class="
                  w-full bg-[#03030b] border border-zinc-800 text-zinc-200
                  px-4 py-2.5 rounded-lg text-sm focus:border-violet-500
                  focus:outline-none
                "
              >
              <p class="text-[10px] text-zinc-500 mt-2 font-mono italic">
                Pull model: <code>ollama pull &lt;model&gt;</code>
              </p>
            </div>
            <p class="text-[10px] text-zinc-500 mt-3 font-mono italic">
              Endpoint: <code><%= ENV.fetch("OLLAMA_BASE_URL", "http://localhost:11434") %></code>
            </p>
          <% else %>
            <select
              name="model_name"
              data-model-selector-target="modelSelect"
              <%= i == 0 ? '' : 'disabled' %>
              class="w-full bg-[#03030b] border border-zinc-800 text-zinc-200 px-4 py-2.5 rounded-lg text-sm focus:border-violet-500 focus:outline-none"
            >
              <% cfg[:models].each do |label, val| %>
                <option value="<%= val %>"><%= label %></option>
              <% end %>
            </select>
          <% end %>
        </div>
      <% end %>
    </div>

    <div
      class="mb-10"
      data-controller="dropzone"
      data-action="dragover->dropzone#dragOver dragleave->dropzone#dragLeave drop->dropzone#drop"
    >
      <label class="block text-[10px] font-bold tracking-widest text-zinc-500 mb-3">IMAGES</label>

      <div
        data-dropzone-target="zone"
        class="
          bg-[#03030b] border-2 border-dashed border-zinc-800 rounded-xl p-16 text-center
          cursor-pointer hover:border-violet-500/50 hover:bg-violet-500/5 transition-all relative group
        "
      >
        <input
          type="file"
          name="images[]"
          multiple
          accept="image/*"
          class="absolute inset-0 opacity-0 cursor-pointer"
          data-dropzone-target="input"
          data-action="change->dropzone#preview"
        >

        <div data-dropzone-target="prompt">
          <div class="text-violet-500 text-5xl mb-4 group-hover:scale-110 transition-transform">⊕</div>
          <p class="text-sm font-semibold text-zinc-300 mb-1">
            Drop images here or click to browse
          </p>
          <p class="text-xs text-zinc-500">
            JPG, PNG, GIF, WebP — multiple files supported
          </p>
        </div>

        <div
          data-dropzone-target="previews"
          class="hidden grid grid-cols-4 gap-4 text-left"
        ></div>
      </div>
    </div>

    <%= f.submit "Start Translation Batch",
          class: "w-full bg-violet-600 text-white font-bold text-sm py-4 rounded-xl hover:bg-violet-700 transition-all shadow-xl shadow-violet-600/20 cursor-pointer" %>
  <% end %>
</div>
