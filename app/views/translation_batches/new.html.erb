<div class="max-w-2xl mx-auto">
  <h1 class="font-['Syne',sans-serif] text-4xl font-black mb-2">Upload Images</h1>
  <p class="text-stone-500 text-sm mb-10">Supports Japanese, Chinese, Korean, and more. Bulk upload supported.</p>

  <%= form_with url: translation_batches_path, method: :post,
        html: { enctype: "multipart/form-data", data: { controller: "upload-form" } } do |f| %>

    <div class="mb-6">
      <%= f.label :title, "Batch Name (optional)", class: "block text-xs text-stone-400 mb-2" %>
      <%= f.text_field :title,
            placeholder: "e.g. Chapter 42 — One Piece",
            class: "w-full bg-stone-900 border border-stone-700 text-stone-100 px-4 py-3 text-sm focus:border-amber-400 focus:outline-none" %>
    </div>

    <div class="mb-8"
          data-controller="dropzone"
          data-action="dragover->dropzone#dragOver dragleave->dropzone#dragLeave drop->dropzone#drop">
      <label class="block text-xs text-stone-400 mb-2">Images</label>
      <div data-dropzone-target="zone"
            class="border-2 border-dashed border-stone-700 p-12 text-center cursor-pointer hover:border-amber-400 transition-colors relative">
        <input type="file" name="images[]" multiple accept="image/*"
                class="absolute inset-0 opacity-0 cursor-pointer"
                data-dropzone-target="input"
                data-action="change->dropzone#preview">
        <div data-dropzone-target="prompt">
          <div class="text-amber-400 text-4xl mb-3">⊕</div>
          <p class="text-sm text-stone-400">Drop images here or click to browse</p>
          <p class="text-xs text-stone-600 mt-1">JPG, PNG, GIF, WebP — unlimited files</p>
        </div>
        <div data-dropzone-target="previews" class="hidden grid grid-cols-4 gap-3 text-left"></div>
      </div>
    </div>

    <%= f.submit "Translate All →",
          class: "w-full bg-amber-400 text-stone-950 font-bold text-sm py-4 hover:bg-amber-300 transition-colors cursor-pointer" %>
  <% end %>
</div>
