<div id="job-<%= job.id %>" class="bg-[#0a0a1a] border border-zinc-800/50 rounded-xl overflow-hidden shadow-2xl">
  <div class="flex items-center justify-between px-6 py-4 border-b border-zinc-800/50 bg-[#0c0c22]">
    <div class="flex items-center gap-4">
      <div class="flex flex-col gap-1">
        <span class="text-[10px] font-bold tracking-widest uppercase text-zinc-500">JOB STATUS</span>
        <span class="text-[10px] font-bold px-2 py-0.5 rounded-full <%= status_badge_classes(job.status) %>">
          <%= job.status.upcase %>
        </span>
      </div>

      <% if job.source_language.present? %>
        <div class="flex flex-col gap-1 border-l border-zinc-800/50 pl-4">
          <span class="text-[10px] font-bold tracking-widest uppercase text-zinc-500">SOURCE</span>
          <span class="text-xs text-zinc-100 font-medium">
            <%= job.source_language %>
          </span>
        </div>
      <% end %>

      <% if job.bubble_count > 0 %>
        <div class="flex flex-col gap-1 border-l border-zinc-800/50 pl-4">
          <span class="text-[10px] font-bold tracking-widest uppercase text-zinc-500">BUBBLES</span>
          <span class="text-xs text-zinc-100 font-medium">
            <%= job.bubble_count %> detected
          </span>
        </div>
      <% end %>
    </div>

    <div class="text-right">
      <span class="text-[10px] font-bold tracking-widest uppercase text-zinc-500 block mb-1">POSITION</span>
      <span class="text-sm font-mono text-zinc-400">#<%= job.position + 1 %></span>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
    <div class="border-b lg:border-b-0 lg:border-r border-zinc-800/50 p-6 bg-[#03030b]/30"
      <% if job.rendered_image.attached? %>
        data-controller="image-toggle"
      <% end %>
    >
      <% if job.rendered_image.attached? %>
        <div class="flex gap-2 mb-6">
          <button
            data-action="click->image-toggle#showOriginal"
            data-image-toggle-target="originalBtn"
            class="
              text-[10px] font-bold tracking-widest uppercase px-3 py-1.5 rounded border border-zinc-700 text-zinc-400
              hover:border-zinc-500 hover:text-zinc-100 transition-all
            ">
            Original
          </button>

          <button
            data-action="click->image-toggle#showTranslated"
            data-image-toggle-target="translatedBtn"
            class="
              text-[10px] font-bold tracking-widest uppercase px-3 py-1.5 rounded border border-violet-500 text-violet-400
              bg-violet-500/10 shadow-lg shadow-violet-500/5
            ">
            Translated ✓
          </button>
        </div>
        <div data-image-toggle-target="originalView" class="hidden ring-1 ring-zinc-800 rounded-lg overflow-hidden">
          <%= image_tag job.image, class: "w-full object-contain max-h-[600px]", alt: "" %>
        </div>
        <div data-image-toggle-target="translatedView" class="ring-1 ring-zinc-800 rounded-lg overflow-hidden">
          <%= image_tag job.rendered_image, class: "w-full object-contain max-h-[600px]", alt: "" %>
        </div>
      <% elsif job.image.attached? %>
        <div class="ring-1 ring-zinc-800 rounded-lg overflow-hidden">
          <%= image_tag job.image, class: "w-full object-contain max-h-[600px]", alt: "" %>
        </div>
      <% end %>
    </div>

    <div class="p-8 flex flex-col gap-8 bg-[#0a0a1a]">
      <div>
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-[10px] font-bold tracking-widest uppercase text-zinc-500">
            Full Page Translation
          </h3>
        </div>

        <div class="bg-[#03030b] border border-zinc-800/50 rounded-xl p-6">
          <% if job.status_completed? && job.translated_text.present? %>
            <div class="text-sm leading-relaxed text-zinc-300 whitespace-pre-wrap"><%= job.translated_text %></div>
            <% if job.error_message.present? %>
              <p class="text-xs text-zinc-500 mt-4 border-t border-zinc-800/50 pt-4 font-italic">
                <%= job.error_message %>
              </p>
            <% end %>
          <% elsif job.status_failed? %>
            <p class="text-sm text-rose-400 font-medium">
              Error: <%= job.error_message %>
            </p>
          <% elsif job.status_processing? %>
            <div class="flex items-center gap-3 text-violet-400 text-sm font-medium">
              <span class="inline-block w-4 h-4 border-2 border-violet-500 border-t-transparent rounded-full animate-spin"></span>
              Translating page content...
            </div>
          <% else %>
            <p class="text-sm text-zinc-600 italic">Waiting in queue...</p>
          <% end %>
        </div>
      </div>

      <% if job.speech_bubbles.any? %>
        <%= render "bubble_details", job: job %>
      <% end %>
    </div>
  </div>
</div>
