<div class="mb-10">
  <h1 class="text-3xl font-bold text-white mb-8">Translation Batches</h1>

  <% if @batches.empty? %>
    <div class="bg-[#0a0a1a] border border-zinc-800 rounded-xl p-20 text-center border-dashed">
      <p class="text-zinc-500 font-medium italic">No batches yet.</p>
      <%= link_to "Create your first batch", new_translation_batch_path,
            class: "mt-4 inline-block text-violet-400 hover:text-violet-300 text-sm font-semibold" %>
    </div>
  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% @batches.each do |batch| %>
        <%= link_to translation_batch_path(batch),
              class: "block bg-[#0a0a1a] border border-zinc-800/50 p-6 rounded-xl hover:border-violet-500/50 transition-all group" do %>
          <div class="flex flex-col h-full">
            <div class="mb-4">
              <span class="text-[10px] font-bold tracking-widest uppercase text-zinc-500 mb-1 block">TITLE</span>
              <p class="text-lg font-bold text-white group-hover:text-violet-400 transition-colors"><%= batch.title %></p>
            </div>

            <div class="mt-auto pt-6 border-t border-zinc-800/50 flex items-center justify-between">
              <div>
                <span class="text-[10px] font-bold tracking-widest uppercase text-zinc-500 block mb-1">IMAGES</span>
                <span class="text-xl font-bold text-white"><%= batch.translation_jobs.size %></span>
              </div>
              <div class="text-right">
                <span class="text-[10px] font-bold tracking-widest uppercase text-zinc-500 block mb-1">STATUS</span>
                <span class="text-xs font-bold px-3 py-1 rounded-full <%= status_badge_classes(batch.status) %>">
                  <%= batch.status.upcase %>
                </span>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
