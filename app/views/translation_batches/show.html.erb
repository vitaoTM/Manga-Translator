 <div data-controller="batch-poller"
      data-batch-poller-batch-id-value="<%= @batch.id %>"
      data-batch-poller-completed-value="<%= @batch.status_completed? || @batch.status_failed? %>"
      class="pb-20">

  <div class="flex items-start justify-between mb-12">
    <div>
      <h1 class="text-3xl font-bold text-white mb-2"><%= @batch.title %></h1>
      <p class="text-zinc-500 text-sm">
        <%= @jobs.size %> image(s) · <span class="text-violet-400 font-medium"><%= @batch.ai_model %></span> ·
        Created <%= time_ago_in_words(@batch.created_at) %> ago
      </p>
    </div>

    <div class="flex flex-col items-end gap-2">
      <span class="text-[10px] font-bold tracking-widest uppercase text-zinc-500">BATCH STATUS</span>
      <span class="text-xs font-bold px-3 py-1 rounded-full <%= status_badge_classes(@batch.status) %>">
        <%= @batch.status.upcase %>
      </span>
      <% if @jobs.any? { |j| j.rendered_image.attached? } %>
        <%= link_to "↓ Download All",
              download_all_translation_batch_path(@batch),
              class: "mt-1 text-[10px] font-bold tracking-widest uppercase
                      px-3 py-1.5 rounded border border-violet-600 text-violet-300 
                      hover:border-violet-400 hover:text-violet-100 transition-all" %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-12">
    <% @jobs.each do |job| %>
      <%= render "translation_job", job: job %>
    <% end %>
  </div>
</div>
