<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Translate Lens</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
      <%= csrf_meta_tags %>
      <%= csp_meta_tag %>
      <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
      <%= javascript_importmap_tags %>
  </head>
  <body class="h-full bg-stone-950 text-stone-100 font-['IBM_Plex_Mono',monospace]">
    <header class="border-b border-stone-800 px-6 py-4 flex items-center justify-between">
      <a href="/" class="font-['Syne',sans-serif] text-2xl font-black tracking-tight text-amber-400">
        TRANSLATE<span class="text-stone-400">LENS</span>
      </a>
      <%= link_to "New Batch", new_translation_batch_path,
            class: "text-xs border border-amber-400 text-amber-400 px-4 py-2 hover:bg-amber-400 hover:text-stone-950 transition-colors" %>
    </header>
    <main class="max-w-6xl mx-auto px-6 py-10">
      <% if notice %>
        <div class="mb-6 border border-green-500 bg-green-950 text-green-300 text-xs px-4 py-3"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="mb-6 border border-red-500 bg-red-950 text-red-300 text-xs px-4 py-3"><%= alert %></div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
