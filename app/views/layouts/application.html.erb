<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Translate Lens</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
      <%= csrf_meta_tags %>
      <%= csp_meta_tag %>
      <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
      <%= javascript_importmap_tags %>
  </head>
  <body class="h-full bg-[#03030b] text-zinc-100 font-sans">
    <header class="border-b border-zinc-800/50 bg-[#03030b]/80 backdrop-blur-sm sticky top-0 z-50 px-8 py-4 flex items-center justify-between">
      <a href="/" class="font-['Syne',sans-serif] text-xl font-black tracking-tight text-violet-500">
        TRANSLATE<span class="text-zinc-400">LENS</span>
      </a>
      <%= link_to "New Batch", new_translation_batch_path,
            class: "text-xs bg-violet-600 text-white font-bold px-4 py-2 rounded-md hover:bg-violet-700 transition-all shadow-lg shadow-violet-500/20" %>
    </header>
    <main class="max-w-6xl mx-auto px-8 py-12">
      <% if notice %>
        <div class="mb-6 border border-green-500 bg-green-950 text-green-300 text-xs px-4 py-3"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="mb-6 border border-red-500 bg-red-950 text-red-300 text-xs px-4 py-3"><%= alert %></div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
